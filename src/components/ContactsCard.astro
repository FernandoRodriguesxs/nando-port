---
import Card from "./Card/index.astro";
import { LINKS } from "../lib/constants";
import { t, type Lang } from "../lib/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-4">
  <div class="h-full">
    <header class="flex items-center">
      <h1 class="text-white text-xl font-bold">
        {t(lang, "contacts.title")}
      </h1>
    </header>
    <address class="flex flex-col mt-4">
      <h2 class="text-gray-500">{t(lang, "contacts.details")}</h2>
      <p>fernando.hardd@gmail.com</p>
      <p>{t(lang, "contacts.location")}</p>
    </address>
    <div class="flex flex-col mt-4 w-fit">
      <h2 class="text-gray-500">{t(lang, "contacts.socials")}</h2>
      <ul>
        <li>
          <a class="cursor-pointer hover:text-primary-500 transition-colors" href={LINKS.linkedin} target="_blank">LinkedIn</a>
        </li>
        <li>
          <a class="cursor-pointer hover:text-primary-500 transition-colors" href={LINKS.github} target="_blank">GitHub</a>
        </li>
        <li>
          <a class="cursor-pointer hover:text-primary-500 transition-colors" href={LINKS.strava} target="_blank">Strava</a>
        </li>
      </ul>
    </div>
  </div>
</Card>
