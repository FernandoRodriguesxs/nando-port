---
import Layout from "../layouts/Layout.astro";
import Card from "./Card/index.astro";
import IntroCard from "./IntroCard.astro";
import ContactsCard from "./ContactsCard.astro";
import LocationCard from "./LocationCard.astro";
import AboutMe from "./AboutMe.astro";
import Now from "./Now.astro";
import MyStack from "./MyStack.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { LINKS } from "../lib/constants";
import { t, type Lang } from "../lib/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<script>
  import { stagger, animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";
  const cards = document.querySelectorAll(".card");

  const sequence = [
    loaderAnimation,
    [
      cards,
      { y: ["40%", "0%"], opacity: [0, 1] },
      {
        type: "spring",
        at: "-0.1",
        delay: stagger(0.3),
      },
    ],
  ];

  animate(sequence as AnimationSequence);
</script>

<Layout
  description={t(lang, "layout.description")}
  title={t(lang, "layout.title")}
>
  <main
    class="text-white m-auto p-4 grid gap-3 max-w-6xl overflow-hidden relative w-full sm:p-4 sm:gap-3 md:grid-cols-2 md:gap-3 md:p-6 lg:h-screen lg:grid-rows-8 lg:grid-cols-4 lg:gap-4 lg:max-h-[800px]"
  >
    <IntroCard lang={lang} />
    <AboutMe lang={lang} />
    <ContactsCard lang={lang} />
    <LocationCard />
    <Now lang={lang} />
    <Card
      colSpan="md:col-span-1"
      href={LINKS.strava}
      rowSpan="md:row-span-2"
      height="h-[140px] md:h-full"
      title={t(lang, "running.title")}
    >
      <div class="flex flex-col items-center justify-center h-full">
        <svg class="strava-float" width="50" height="50" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M41.03 43.2l-5.56-10.85h-7.1L41.03 57.6l12.66-25.25h-7.1L41.03 43.2z" fill="#F9521E"/>
          <path d="M28.37 32.35L35.47 32.35 22.97 6.4 10.31 32.35h7.1l5.56-10.85 5.4 10.85z" fill="#FC4C02"/>
        </svg>
      </div>
    </Card>
    <Card
      colSpan="md:col-span-1"
      href="https://open.spotify.com/user/lc2jf46ut0z1zxollqwidybrj"
      rowSpan="md:row-span-2"
      height="h-[140px] md:h-full"
      title={t(lang, "spotify.title")}
    >
      <div class="flex flex-col items-center justify-center h-full">
        <svg class="spotify-float" width="50" height="50" viewBox="0 0 168 168" xmlns="http://www.w3.org/2000/svg">
          <path fill="#1ED760" d="M83.996.277C37.747.277.253 37.77.253 84.019c0 46.251 37.494 83.741 83.743 83.741 46.254 0 83.744-37.49 83.744-83.741C167.74 37.77 130.25.277 83.996.277zm38.404 120.78a5.217 5.217 0 01-7.18 1.73c-19.662-12.01-44.414-14.73-73.564-8.07a5.222 5.222 0 01-6.249-3.93 5.213 5.213 0 013.926-6.25c31.9-7.291 59.263-4.15 81.337 9.34 2.46 1.51 3.24 4.72 1.73 7.18zm10.25-22.805c-1.89 3.075-5.91 4.045-8.98 2.155-22.51-13.839-56.823-17.846-83.448-9.764-3.453 1.043-7.1-.903-8.148-4.35a6.538 6.538 0 014.354-8.143c30.413-9.228 68.222-4.758 94.072 11.127 3.07 1.89 4.04 5.91 2.15 8.976zm.88-23.744c-26.99-16.031-71.52-17.505-97.289-9.684-4.138 1.255-8.514-1.081-9.768-5.219a7.835 7.835 0 015.221-9.771c29.581-8.98 78.756-7.245 109.83 11.202a7.823 7.823 0 012.74 10.733 7.823 7.823 0 01-10.734 2.74z"/>
        </svg>
      </div>
    </Card>
    <Card colSpan="md:col-span-1" rowSpan="md:row-span-1">
      <div class="flex justify-between items-center gap-4">
        <p class="text-xs">
          &copy; 2026 &middot; {t(lang, "footer.by")}
        </p>
        <LanguageSwitcher lang={lang} />
      </div>
    </Card>
  </main>
</Layout>

<style>
  @keyframes strava-float {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  .strava-float {
    animation: strava-float 3s ease-in-out infinite;
    filter: drop-shadow(0 8px 16px rgba(252, 76, 2, 0.3));
  }

  @keyframes spotify-float {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  .spotify-float {
    animation: spotify-float 3s ease-in-out infinite;
    filter: drop-shadow(0 8px 16px rgba(30, 215, 96, 0.3));
  }
</style>
